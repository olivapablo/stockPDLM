{
  "rules": {
    "stock": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('usuarios').child(auth.uid).child('role').val() == 'admin' || root.child('usuarios').child(auth.uid).child('role').val() == 'editor')"
    },
    "usuarios": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('usuarios').child(auth.uid).child('role').val() == 'admin'"
    },
    "usuarios_pendientes": {
      ".read": "auth != null && root.child('usuarios').child(auth.uid).child('role').val() == 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && (root.child('usuarios').child(auth.uid).child('role').val() == 'admin' || (auth.uid == $uid && !data.exists()))"
      }
    }
  }
}
